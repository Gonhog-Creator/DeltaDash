# Local development
APP_ENV=development
DATABASE_URL=postgresql+psycopg://ballistic_user:ballistic_pass@postgres:5432/ballistic
SECRET_KEY=replace_with_long_random_secret_key_at_least_32_characters
ACCESS_TOKEN_EXPIRE_MINUTES=60
UPLOAD_DIR=/app/storage/uploads
MATERIAL_DOCS_DIR=/app/storage/material_docs
REPORTS_DIR=/app/storage/reports
MODEL_ARTIFACTS_DIR=/app/storage/model_artifacts
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Railway production (set these as environment variables in Railway dashboard)
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>:<port>/<db>  <- Railway provides this automatically when you add a Postgres plugin
# SECRET_KEY=<generate with: python -c "import secrets; print(secrets.token_hex(32))">
# CORS_ORIGINS=https://your-frontend.railway.app
